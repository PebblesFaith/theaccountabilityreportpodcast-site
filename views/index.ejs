<section class="hero hero--dark" aria-labelledby="home-hero-title">
  <div class="hero__grid site-container">
    <div class="hero__content">
      <span class="hero__eyebrow">Investigative · Public-Interest</span>

      <h1 id="home-hero-title" class="hero__title">
        The Accountability Report <span>Podcast</span>
      </h1>

      <p class="hero__lead">
        Investigative reporting on fraud, identity theft, digital misuse, consumer protection,
        and accountability.
      </p>

      <div class="hero__actions" aria-label="Homepage actions">
        <a class="button button-accent hero__button" href="/episodes" data-coming-soon>
          <svg class="button__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M6.75 10.5v3"></path>
            <path d="M17.25 10.5v3"></path>
            <path d="M7.5 16.5a6 6 0 0 1 9 0"></path>
            <path d="M5.25 12a6.75 6.75 0 0 1 13.5 0"></path>
            <path d="M4.5 13.5c0-4.14 3.36-7.5 7.5-7.5s7.5 3.36 7.5 7.5"></path>
          </svg>
          Podcast Platforms Coming Soon
        </a>

        <a class="button button-outline-light hero__button" href="/submit-tip">
          <svg class="button__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="m21 3-7.5 18-4.25-7.75L1.5 9 21 3Z"></path>
            <path d="M9.25 13.25 21 3"></path>
          </svg>
          Submit a Story Tip
        </a>

        <a class="button button-outline-light hero__button" href="/reports">
          <svg class="button__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M6.75 3.75h7.5L18.75 8.25v12H6.75v-16.5Z"></path>
            <path d="M14.25 3.75v4.5h4.5"></path>
            <path d="M9 12h6"></path>
            <path d="M9 15h6"></path>
          </svg>
          View Latest Reports
        </a>
      </div>
    </div>

    <aside class="hero__record-panel" aria-labelledby="hero-record-title">
      <p class="hero__record-kicker">On The Record</p>

      <div class="hero__record-row">
        <span>01</span>
        <strong>Documented Concerns</strong>
      </div>

      <div class="hero__record-row">
        <span>02</span>
        <strong>Timeline Reviews</strong>
      </div>

      <div class="hero__record-row">
        <span>03</span>
        <strong>Public-Interest Reports</strong>
      </div>

      <div class="hero__record-row">
        <span>04</span>
        <strong>Consumer Protection Briefs</strong>
      </div>

      <p id="hero-record-title" class="hero__record-note">
        Hosted by Sarai Hannah Ajai. New episodes will be published as investigations are
        documented and reviewed.
      </p>
    </aside>
  </div>
</section>

<section class="mission-section" aria-labelledby="mission-title">
  <div class="site-container mission-section__inner">
    <span class="section-label">Mission</span>

    <h2 id="mission-title" class="mission-section__title">
      The Accountability Report Podcast examines documented concerns involving fraud,
      identity misuse, digital compromise, consumer protection failures, and public-interest
      accountability.
    </h2>

    <p class="mission-section__text">
      Each episode is designed to inform, document, and help listeners understand practical
      protection steps.
    </p>
  </div>
</section>

