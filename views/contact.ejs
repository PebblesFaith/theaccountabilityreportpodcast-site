<%# views/contact.ejs %>
<%- include("partials/header", {
  pageTitle: "Contact",
  activeNav: "contact",
  pageClass: "contact-page",
  pageStyles: ["/styles/contact.css"],
  canonicalPath: "/contact/",
  metaDescription: "Contact information for The Accountability Report Podcast, including planned domain-based addresses for media, tips, corrections, legal notices, and general contact."
}) %>

<section class="contact-hero" aria-labelledby="contact-page-title">
  <div class="site-container contact-hero__content">
    <span class="contact-kicker">Contact</span>

    <h1 id="contact-page-title" class="contact-hero__title">
      Get in touch
    </h1>

    <p class="contact-hero__lead">
      Official contact information will be provided through TheAccountabilityReportPodcast.com.
      Domain-based contact addresses are planned for media, story tips, corrections, legal
      notices, and general contact.
    </p>
  </div>
</section>

<section class="contact-content" aria-labelledby="contact-content-title">
  <div class="site-container contact-content__inner">
    <h2 id="contact-content-title" class="screen-reader-text">
      Contact details
    </h2>

    <aside class="contact-notice" aria-label="Story tip notice">
      <p>
        Story tip submissions will become available after the official privacy, storage,
        and review procedures are finalized.
      </p>
    </aside>

    <article class="contact-card" aria-labelledby="primary-website-title">
      <div class="contact-card__label">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="8.25"></circle>
          <path d="M3.75 12h16.5"></path>
          <path d="M12 3.75c2.15 2.25 3.25 5 3.25 8.25S14.15 18 12 20.25"></path>
          <path d="M12 3.75C9.85 6 8.75 8.75 8.75 12S9.85 18 12 20.25"></path>
        </svg>
        <span>Primary Website</span>
      </div>

      <h3 id="primary-website-title">
        TheAccountabilityReportPodcast.com
      </h3>

      <p>
        A shorter related domain, AccountabilityReportPodcast.com, may later redirect to
        the primary website.
      </p>
    </article>

    <article class="contact-card" aria-labelledby="future-addresses-title">
      <div class="contact-card__label">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M4.5 6.75h15v10.5h-15V6.75Z"></path>
          <path d="m4.5 7.5 7.5 5.25L19.5 7.5"></path>
        </svg>
        <span>Future Domain-Based Addresses</span>
      </div>

      <h3 id="future-addresses-title" class="screen-reader-text">
        Planned contact addresses
      </h3>

      <dl class="contact-directory">
        <div class="contact-directory__row">
          <dt>Media inquiries, interviews, and podcast communication</dt>
          <dd>media@theaccountabilityreportpodcast.com</dd>
        </div>

        <div class="contact-directory__row">
          <dt>Future story tips and documentation-related inquiries</dt>
          <dd>tips@theaccountabilityreportpodcast.com</dd>
        </div>

        <div class="contact-directory__row">
          <dt>General contact</dt>
          <dd>contact@theaccountabilityreportpodcast.com</dd>
        </div>

        <div class="contact-directory__row">
          <dt>Corrections, legal notices, and formal communication</dt>
          <dd>legal@theaccountabilityreportpodcast.com</dd>
        </div>
      </dl>

      <p class="contact-card__note">
        These are planned domain-based addresses and should be activated before being used
        publicly. Gmail is not listed as the official public brand email.
      </p>
    </article>
  </div>
</section>

<%- include("partials/footer") %>